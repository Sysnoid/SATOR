SATOR_API_KEY=dev-key
SATOR_RATE_LIMIT_PER_MIN=300
SATOR_IP_WHITELIST=
SATOR_IP_BLACKLIST=
# Comma-separated IPs or CIDRs of reverse proxies. When the direct TCP client matches, X-Forwarded-For is honored for IP policy & rate limit. Leave empty to ignore XFF (recommended when not behind a known proxy).
SATOR_TRUSTED_PROXY_CIDRS=
SATOR_ENABLE_HTTP=true
SATOR_HTTP_HOST=0.0.0.0
# Docker Compose: map host port to container 8080 (see docs/03-installation.md)
# SATOR_HOST_PORT=8080
# SATOR_GPU_HOST_PORT=8081
LOG_LEVEL=info
LOG_FORMAT=human
LOG_TO_FILE=false
LOG_FILE_PATH=
SATOR_DEVICE=cpu
SATOR_CUDA_DEVICE=0
SATOR_RESULT_TTL_SEC=600
SATOR_JOB_TIMEOUT_SEC=300
SATOR_CONCURRENCY=4
# Prometheus (bind/mTLS should be handled by your reverse proxy; disable on untrusted networks)
SATOR_ENABLE_METRICS=true
SATOR_STORE_SWEEP_INTERVAL_SEC=60
SATOR_RATE_LIMIT_MAX_KEYS=50000
# Set true only in development if you need exception text in 500 JSON responses
SATOR_EXPOSE_ERROR_DETAILS=false
SATOR_ENABLE_TLS=true
SATOR_HTTP_PORT=8443
SATOR_TLS_CERT_FILE=certs/localhost.pem
SATOR_TLS_KEY_FILE=certs/localhost-key.pem